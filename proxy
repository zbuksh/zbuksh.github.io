<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Proxy Server & Domain Routing Configurator</title>

  <style>
    :root {
      --bg: #f5f5f7;
      --panel: rgba(255, 255, 255, 0.72);
      --panel-strong: rgba(255, 255, 255, 0.9);
      --text: #1d1d1f;
      --muted: #6e6e73;
      --border: rgba(0, 0, 0, 0.08);
      --blue: #007aff;
      --green: #34c759;
      --red: #ff3b30;
      --yellow: #ffcc00;
      --shadow: 0 24px 60px rgba(0, 0, 0, 0.14);
      --radius: 24px;
      --mono: "SF Mono", Consolas, Monaco, monospace;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 10% 10%, rgba(0, 122, 255, 0.22), transparent 28%),
        radial-gradient(circle at 90% 20%, rgba(175, 82, 222, 0.16), transparent 28%),
        radial-gradient(circle at 70% 90%, rgba(52, 199, 89, 0.14), transparent 30%),
        var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px;
    }

    .app-window {
      width: 100%;
      max-width: 1220px;
      border-radius: 32px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.58);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border: 1px solid rgba(255, 255, 255, 0.7);
      box-shadow: var(--shadow);
    }

    .title-bar {
      height: 58px;
      padding: 0 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(255, 255, 255, 0.42);
      border-bottom: 1px solid var(--border);
    }

    .traffic-lights {
      display: flex;
      gap: 9px;
    }

    .light {
      width: 13px;
      height: 13px;
      border-radius: 50%;
    }

    .light.red {
      background: #ff5f57;
    }

    .light.yellow {
      background: #ffbd2e;
    }

    .light.green {
      background: #28c840;
    }

    .title {
      font-size: 14px;
      color: var(--muted);
      font-weight: 700;
    }

    .status {
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(52, 199, 89, 0.14);
      color: #178a3a;
      font-size: 13px;
      font-weight: 700;
      border: 1px solid rgba(52, 199, 89, 0.22);
    }

    .layout {
      display: grid;
      grid-template-columns: 390px 1fr;
      gap: 24px;
      padding: 28px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 12px 35px rgba(0, 0, 0, 0.07);
      padding: 22px;
    }

    .hero h1 {
      margin: 0;
      font-size: 34px;
      letter-spacing: -1px;
    }

    .hero p {
      margin: 10px 0 24px;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.5;
    }

    .form-group {
      margin-bottom: 17px;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-size: 13px;
      font-weight: 700;
      color: var(--muted);
    }

    input,
    select {
      width: 100%;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.85);
      border-radius: 15px;
      padding: 13px 14px;
      font-size: 15px;
      color: var(--text);
      outline: none;
      transition: all 0.18s ease;
    }

    input:focus,
    select:focus {
      border-color: rgba(0, 122, 255, 0.55);
      box-shadow: 0 0 0 4px rgba(0, 122, 255, 0.13);
      background: #fff;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .button-row {
      display: flex;
      gap: 12px;
      margin-top: 20px;
    }

    button {
      border: 0;
      border-radius: 15px;
      padding: 13px 16px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.16s ease;
      white-space: nowrap;
    }

    button:hover {
      transform: translateY(-1px);
    }

    button:active {
      transform: translateY(0);
      opacity: 0.86;
    }

    .btn-primary {
      flex: 1;
      background: var(--blue);
      color: #fff;
      box-shadow: 0 10px 22px rgba(0, 122, 255, 0.28);
    }

    .btn-secondary {
      background: rgba(0, 0, 0, 0.06);
      color: var(--text);
    }

    .btn-danger {
      background: rgba(255, 59, 48, 0.12);
      color: var(--red);
      padding: 9px 12px;
    }

    .main-area {
      display: grid;
      gap: 24px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 15px;
    }

    .section-header h2 {
      margin: 0;
      font-size: 21px;
      letter-spacing: -0.4px;
    }

    .hint {
      color: var(--muted);
      font-size: 13px;
      font-weight: 600;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .stat-card {
      background: var(--panel-strong);
      border: 1px solid var(--border);
      border-radius: 19px;
      padding: 16px;
    }

    .stat-value {
      font-size: 24px;
      font-weight: 900;
      letter-spacing: -0.6px;
    }

    .stat-label {
      margin-top: 4px;
      font-size: 13px;
      color: var(--muted);
      font-weight: 600;
    }

    .routes {
      display: grid;
      gap: 12px;
    }

    .route-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      align-items: center;
      padding: 16px;
      background: var(--panel-strong);
      border: 1px solid var(--border);
      border-radius: 19px;
    }

    .route-domain {
      font-size: 15px;
      font-weight: 900;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .route-target {
      margin-top: 5px;
      font-size: 13px;
      color: var(--muted);
      font-weight: 600;
    }

    .tag {
      display: inline-block;
      margin-top: 9px;
      padding: 5px 9px;
      border-radius: 999px;
      background: rgba(0, 122, 255, 0.11);
      color: var(--blue);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.2px;
    }

    .code-actions {
      display: flex;
      gap: 10px;
    }

    pre {
      margin: 0;
      max-height: 430px;
      overflow: auto;
      background: #1e1e1e;
      color: #f5f5f7;
      padding: 20px;
      border-radius: 19px;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.6;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .empty {
      padding: 18px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.7);
      color: var(--muted);
      font-weight: 700;
      border: 1px dashed rgba(0, 0, 0, 0.13);
    }

    .toast {
      position: fixed;
      right: 28px;
      bottom: 28px;
      background: rgba(29, 29, 31, 0.9);
      color: white;
      padding: 13px 18px;
      border-radius: 16px;
      font-size: 14px;
      font-weight: 700;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
      opacity: 0;
      pointer-events: none;
      transform: translateY(12px);
      transition: all 0.25s ease;
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 980px) {
      body {
        padding: 18px;
      }

      .layout {
        grid-template-columns: 1fr;
      }

      .stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 560px) {
      .title {
        display: none;
      }

      .layout {
        padding: 18px;
      }

      .grid-2,
      .stats {
        grid-template-columns: 1fr;
      }

      .section-header {
        align-items: flex-start;
        flex-direction: column;
      }

      .code-actions {
        width: 100%;
      }

      .code-actions button {
        flex: 1;
      }
    }
  </style>
</head>

<body>
  <div class="app-window">
    <header class="title-bar">
      <div class="traffic-lights">
        <span class="light red"></span>
        <span class="light yellow"></span>
        <span class="light green"></span>
      </div>

      <div class="title">Proxy Server & Domain Routing Configurator</div>

      <div class="status">Config Ready</div>
    </header>

    <main class="layout">
      <aside class="panel">
        <div class="hero">
          <h1>Proxy Router</h1>
          <p>
            Configure domain routes to specific server addresses and generate a Go language config.
          </p>
        </div>

        <div class="form-group">
          <label for="proxyName">Proxy Name</label>
          <input id="proxyName" type="text" value="GoProxyRouter" />
        </div>

        <div class="grid-2">
          <div class="form-group">
            <label for="proxyHost">Proxy Host</label>
            <input id="proxyHost" type="text" value="127.0.0.1" />
          </div>

          <div class="form-group">
            <label for="proxyPort">Proxy Port</label>
            <input id="proxyPort" type="number" value="8080" />
          </div>
        </div>

        <div class="form-group">
          <label for="domainInput">Domain</label>
          <input id="domainInput" type="text" value="zbuksh.github.io" />
        </div>

        <div class="form-group">
          <label for="serverInput">Target Server Address</label>
          <input id="serverInput" type="text" value="8.8.8.8" />
        </div>

        <div class="grid-2">
          <div class="form-group">
            <label for="protocolInput">Protocol</label>
            <select id="protocolInput">
              <option value="http">HTTP</option>
              <option value="https" selected>HTTPS</option>
              <option value="tcp">TCP</option>
              <option value="udp">UDP</option>
            </select>
          </div>

          <div class="form-group">
            <label for="portInput">Target Port</label>
            <input id="portInput" type="number" value="443" />
          </div>
        </div>

        <div class="button-row">
          <button class="btn-primary" onclick="addOrUpdateRoute()">Add / Update</button>
          <button class="btn-secondary" onclick="resetConfig()">Reset</button>
        </div>
      </aside>

      <section class="main-area">
        <section class="panel">
          <div class="section-header">
            <h2>Configuration Summary</h2>
            <span class="hint">Live preview</span>
          </div>

          <div class="stats">
            <div class="stat-card">
              <div class="stat-value" id="routeCount">1</div>
              <div class="stat-label">Routes</div>
            </div>

            <div class="stat-card">
              <div class="stat-value" id="proxyAddress">127.0.0.1:8080</div>
              <div class="stat-label">Proxy Address</div>
            </div>

            <div class="stat-card">
              <div class="stat-value">Go</div>
              <div class="stat-label">Config Type</div>
            </div>

            <div class="stat-card">
              <div class="stat-value" id="primaryRoute">8.8.8.8</div>
              <div class="stat-label">Primary Target</div>
            </div>
          </div>
        </section>

        <section class="panel">
          <div class="section-header">
            <h2>Domain Routing Rules</h2>
            <span class="hint">Domain → Server</span>
          </div>

          <div id="routeList" class="routes"></div>
        </section>

        <section class="panel">
          <div class="section-header">
            <h2>Generated Go Config</h2>

            <div class="code-actions">
              <button class="btn-secondary" onclick="copyConfig()">Copy</button>
              <button class="btn-secondary" onclick="downloadGoFile()">Download .go</button>
            </div>
          </div>

          <pre id="goConfig"></pre>
        </section>
      </section>
    </main>
  </div>

  <div id="toast" class="toast">Done</div>

  <script>
    let routes = [
      {
        domain: "zbuksh.github.io",
        server: "8.8.8.8",
        protocol: "https",
        targetPort: 443
      }
    ];

    const proxyName = document.getElementById("proxyName");
    const proxyHost = document.getElementById("proxyHost");
    const proxyPort = document.getElementById("proxyPort");

    const domainInput = document.getElementById("domainInput");
    const serverInput = document.getElementById("serverInput");
    const protocolInput = document.getElementById("protocolInput");
    const portInput = document.getElementById("portInput");

    const routeList = document.getElementById("routeList");
    const goConfig = document.getElementById("goConfig");
    const routeCount = document.getElementById("routeCount");
    const proxyAddress = document.getElementById("proxyAddress");
    const primaryRoute = document.getElementById("primaryRoute");
    const toast = document.getElementById("toast");

    function addOrUpdateRoute() {
      const domain = domainInput.value.trim();
      const server = serverInput.value.trim();
      const protocol = protocolInput.value;
      const targetPort = Number(portInput.value);

      if (!domain || !server || !targetPort) {
        showToast("Enter domain, server and target port");
        return;
      }

      const route = {
        domain,
        server,
        protocol,
        targetPort
      };

      const existingIndex = routes.findIndex(
        item => item.domain.toLowerCase() === domain.toLowerCase()
      );

      if (existingIndex >= 0) {
        routes[existingIndex] = route;
        showToast("Route updated");
      } else {
        routes.push(route);
        showToast("Route added");
      }

      render();
    }

    function deleteRoute(index) {
      routes.splice(index, 1);
      showToast("Route deleted");
      render();
    }

    function loadRoute(index) {
      const route = routes[index];

      domainInput.value = route.domain;
      serverInput.value = route.server;
      protocolInput.value = route.protocol;
      portInput.value = route.targetPort;

      showToast("Route loaded for editing");
    }

    function resetConfig() {
      proxyName.value = "GoProxyRouter";
      proxyHost.value = "127.0.0.1";
      proxyPort.value = "8080";

      domainInput.value = "zbuksh.github.io";
      serverInput.value = "8.8.8.8";
      protocolInput.value = "https";
      portInput.value = "443";

      routes = [
        {
          domain: "zbuksh.github.io",
          server: "8.8.8.8",
          protocol: "https",
          targetPort: 443
        }
      ];

      showToast("Sample config restored");
      render();
    }

    function renderRoutes() {
      routeList.innerHTML = "";

      if (routes.length === 0) {
        routeList.innerHTML = `
          <div class="empty">
            No routes configured. Add a domain route to generate Go config.
          </div>
        `;
        return;
      }

      routes.forEach((route, index) => {
        const card = document.createElement("div");
        card.className = "route-card";

        card.innerHTML = `
          <div>
            <div class="route-domain">${escapeHtml(route.domain)}</div>
            <div class="route-target">
              Routes to ${escapeHtml(route.server)}:${escapeHtml(route.targetPort)}
            </div>
            <span class="tag">${escapeHtml(route.protocol.toUpperCase())}</span>
          </div>

          <div class="button-row">
            <button class="btn-secondary" onclick="loadRoute(${index})">Edit</button>
            <button class="btn-danger" onclick="deleteRoute(${index})">Delete</button>
          </div>
        `;

        routeList.appendChild(card);
      });
    }

    function generateGoConfig() {
      const cleanProxyName = sanitizeGoString(proxyName.value || "GoProxyRouter");
      const cleanProxyHost = sanitizeGoString(proxyHost.value || "127.0.0.1");
      const cleanProxyPort = Number(proxyPort.value || 8080);

      const routeBlocks = routes.map(route => {
        return `        {
            Domain:     "${sanitizeGoString(route.domain)}",
            Server:     "${sanitizeGoString(route.server)}",
            Protocol:   "${sanitizeGoString(route.protocol)}",
            TargetPort: ${Number(route.targetPort)},
        }`;
      }).join(",\n");

      return `package main

import (
    "fmt"
    "net/http"
)

type RouteConfig struct {
    Domain     string
    Server     string
    Protocol   string
    TargetPort int
}

type ProxyConfig struct {
    Name   string
    Host   string
    Port   int
    Routes []RouteConfig
}

var config = ProxyConfig{
    Name: "${cleanProxyName}",
    Host: "${cleanProxyHost}",
    Port: ${cleanProxyPort},
    Routes: []RouteConfig{
${routeBlocks}
    },
}

func main() {
    proxyAddress := fmt.Sprintf("%s:%d", config.Host, config.Port)

    fmt.Println("Starting proxy server:", config.Name)
    fmt.Println("Listening on:", proxyAddress)

    for _, route := range config.Routes {
        fmt.Printf(
            "Route configured: %s -> %s://%s:%d\\n",
            route.Domain,
            route.Protocol,
            route.Server,
            route.TargetPort,
        )
    }

    http.HandleFunc("/", func(w http.ResponseWriter, r *http.Request) {
        requestedHost := r.Host

        for _, route := range config.Routes {
            if requestedHost == route.Domain {
                target := fmt.Sprintf(
                    "%s://%s:%d",
                    route.Protocol,
                    route.Server,
                    route.TargetPort,
                )

                fmt.Fprintf(w, "Matched route: %s -> %s", route.Domain, target)
                return
            }
        }

        http.Error(w, "No route configured for this domain", http.StatusNotFound)
    })

    if err := http.ListenAndServe(proxyAddress, nil); err != nil {
        panic(err)
    }
}
`;
    }

    function renderSummary() {
      routeCount.textContent = routes.length;
      proxyAddress.textContent = `${proxyHost.value || "127.0.0.1"}:${proxyPort.value || "8080"}`;
      primaryRoute.textContent = routes[0] ? routes[0].server : "N/A";
    }

    function renderGoConfig() {
      goConfig.textContent = generateGoConfig();
    }

    function render() {
      renderRoutes();
      renderSummary();
      renderGoConfig();
    }

    async function copyConfig() {
      try {
        await navigator.clipboard.writeText(generateGoConfig());
        showToast("Go config copied");
      } catch (error) {
        showToast("Copy failed");
      }
    }

    function downloadGoFile() {
      const content = generateGoConfig();
      const blob = new Blob([content], { type: "text/plain;charset=utf-8" });
      const url = URL.createObjectURL(blob);

      const link = document.createElement("a");
      link.href = url;
      link.download = "proxy-router-config.go";
      document.body.appendChild(link);
      link.click();

      document.body.removeChild(link);
      URL.revokeObjectURL(url);

      showToast("Go config downloaded");
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");

      setTimeout(() => {
        toast.classList.remove("show");
      }, 2200);
    }

    function sanitizeGoString(value) {
      return String(value)
        .replace(/\\/g, "\\\\")
        .replace(/"/g, '\\"')
        .replace(/\n/g, "")
        .replace(/\r/g, "");
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    proxyName.addEventListener("input", render);
    proxyHost.addEventListener("input", render);
    proxyPort.addEventListener("input", render);

    protocolInput.addEventListener("change", function () {
      if (protocolInput.value === "https") {
        portInput.value = 443;
      }

      if (protocolInput.value === "http") {
        portInput.value = 80;
      }

      if (protocolInput.value === "tcp") {
        portInput.value = 9000;
      }

      if (protocolInput.value === "udp") {
        portInput.value = 5353;
      }
    });

    render();
  </script>
</body>
</html>
